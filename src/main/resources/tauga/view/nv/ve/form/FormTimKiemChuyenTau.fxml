<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.jfoenix.controls.JFXComboBox?>
<!--<AnchorPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
           AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">-->
<StackPane
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.nv.ve.form.FormTimKiemChuyenTau"
           prefWidth="810" prefHeight="880"
           maxWidth="Infinity"
           maxHeight="Infinity"
           style="-fx-background-color: white;">

    <children>
        <!-- Form căn giữa màn hình -->
        <VBox alignment="TOP_CENTER" spacing="20"
              prefWidth="600"
              fillWidth="true"
              style="-fx-border-color: #ccc; -fx-border-radius: 10; -fx-padding: 5; -fx-background-color: #f9f9f9;"
              StackPane.alignment="CENTER">

            <!-- Tiêu đề -->
            <Label text="CHỌN THÔNG TIN CHUYẾN ĐI"
                   style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #333;"/>

            <!-- Form nội dung -->
            <HBox alignment="CENTER">
                <children>
                    <GridPane hgap="15" vgap="12" alignment="CENTER">
                        <columnConstraints>
                            <!-- Label căn trái -->
                            <ColumnConstraints halignment="LEFT" minWidth="120" prefWidth="140"/>
                            <!-- Ô nhập liệu chiếm phần còn lại -->
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" prefWidth="220"/>
                        </columnConstraints>

                        <Label text="Ga đi:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <JFXComboBox fx:id="cbbGaDi" editable="true" prefWidth="220"
                                     GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Ga đến:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <JFXComboBox fx:id="cbbGaDen" editable="true" prefWidth="220"
                                     GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Loại vé:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <HBox spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <children>
                                <RadioButton fx:id="radMotChieu" text="Một chiều"/>
                                <RadioButton fx:id="radKhuHoi" text="Khứ hồi"/>
                            </children>
                        </HBox>

                        <Label text="Ngày đi:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <DatePicker fx:id="dpNgayDi" prefWidth="220"
                                    GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Ngày về (Khứ hồi):" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <DatePicker fx:id="dpNgayVe" prefWidth="220"
                                    GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                        <Label text="Loại ghế/giường:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <JFXComboBox fx:id="cbboLoaiGheGiuong" editable="true" prefWidth="220"
                                     GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    </GridPane>
                </children>
            </HBox>

            <!-- Nút tìm kiếm -->
            <HBox alignment="CENTER" spacing="10">
                <children>
                    <Button fx:id="btnTimKiem" onAction="#onTimKiem"
                            text="Tìm kiếm"
                            style="-fx-background-color: #52CCF6; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25;"/>
                </children>
            </HBox>
        </VBox>
    </children>

</StackPane>
<!--</AnchorPane>-->