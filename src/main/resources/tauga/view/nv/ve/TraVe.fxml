<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.nv.ve.TraVe"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: transparent;"
            fx:id="main">

    <!-- phan code -->
    <SplitPane fx:id="mainSplit"
               orientation="HORIZONTAL"
               dividerPositions="0.5"
               AnchorPane.topAnchor="0.0"
               AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0"
               style="-fx-border-color: gray;">

        <items>
            <VBox>
                <BorderPane BorderPane.alignment="CENTER">
                    <top>
                        <VBox alignment="TOP_CENTER" style="-fx-border-color: gray;"
                              BorderPane.alignment="CENTER">
                            <children>
                                <Label alignment="CENTER"
                                       style="-fx-font-weight: bold; -fx-font-size: 16;"
                                       text="TÌM KIẾM THÔNG TIN KHÁCH HÀNG">
                                    <font>
                                        <Font size="16.0"/>
                                    </font>
                                    <VBox.margin>
                                        <Insets top="10.0"/>
                                    </VBox.margin>
                                </Label>
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <Label text="Chọn cách thức tra cứu:">
                                            <font>
                                                <Font size="13.0"/>
                                            </font>
                                        </Label>
                                        <RadioButton fx:id="radMaVe" mnemonicParsing="false"
                                                     text="Mã vé">
                                            <font>
                                                <Font size="13.0"/>
                                            </font>

                                        </RadioButton>
                                        <RadioButton fx:id="radThongTinKH"
                                                     mnemonicParsing="false"
                                                     text="Thông tin khách hàng">
                                            <font>
                                                <Font size="13.0"/>
                                            </font>
                                        </RadioButton>
                                    </children>
                                    <VBox.margin>
                                        <Insets left="20.0" top="10.0"/>
                                    </VBox.margin>
                                    <padding>
                                        <Insets bottom="15.0"/>
                                    </padding>
                                </HBox>
                                <HBox fx:id="HBoxMaVe" alignment="CENTER_LEFT"
                                      spacing="30.0">
                                    <children>
                                        <Label text="Mã vé:"/>
                                        <TextField fx:id="txtMaVe"/>
                                        <ImageView fitHeight="27.0" fitWidth="24.0"
                                                   pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../img/qr.png"/>
                                            </image>
                                        </ImageView>
                                    </children>
                                    <VBox.margin>
                                        <Insets left="20.0"/>
                                    </VBox.margin>
                                </HBox>
                                <HBox fx:id="HBoxThongTinKH" alignment="CENTER_LEFT"
                                      managed="false"
                                      spacing="10.0" visible="false">
                                    <children>
                                        <Label fx:id="lblSDT" text="Số điện thoại:">

                                        </Label>
                                        <TextField fx:id="txtSDT"/>
                                        <Label fx:id="lblCCCD" text="CCCD:">

                                        </Label>
                                        <TextField fx:id="txtCCCD"/>
                                    </children>
                                    <VBox.margin>
                                        <Insets left="20.0"/>
                                    </VBox.margin>
                                </HBox>
                                <HBox alignment="CENTER_RIGHT" spacing="30.0">
                                    <children>
                                        <Button fx:id="btnTimKiem" mnemonicParsing="false"
                                                onAction="#TimKiem"
                                                style="-fx-background-color: #52CCF6; -fx-text-fill: white"
                                                text="Tìm kiếm"/>
                                        <Button fx:id="btnTraVe" mnemonicParsing="false"
                                                onAction="#TraVe"
                                                style="-fx-background-color: #52CCF6; -fx-text-fill: white"
                                                text="Trả vé"/>
                                    </children>
                                    <VBox.margin>
                                        <Insets right="20.0" top="10.0"/>
                                    </VBox.margin>
                                </HBox>
                                <TableView fx:id="table" prefHeight="207.0"
                                           prefWidth="480.0"
                                           VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colMaVe" text="Mã vé"/>
                                        <TableColumn fx:id="colTenKH" text="Khách hàng"/>
                                        <TableColumn fx:id="colChuyenTau"
                                                     text="Chuyến tàu"/>
                                        <TableColumn fx:id="colNgayDat" text="Ngày đặt"/>
                                        <TableColumn fx:id="colGiaVe" text="Giá vé"/>
                                        <TableColumn fx:id="colTrangThaiVe"
                                                     text="Trạng thái vé"/>
                                    </columns>
                                    <VBox.margin>
                                        <Insets top="10.0"/>
                                    </VBox.margin>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </top>
                    <center>
                        <VBox spacing="20.0" style="-fx-border-color: gray;"
                              BorderPane.alignment="CENTER">
                            <children>
                                <HBox alignment="CENTER">
                                    <children>
                                        <ImageView pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../img/warning.png"/>
                                            </image>
                                        </ImageView>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;"
                                               text="QUY ĐỊNH VỀ TRẢ VÉ">
                                            <font>
                                                <Font size="16.0"/>
                                            </font>
                                        </Label>
                                    </children>
                                    <padding>
                                        <Insets top="15.0"/>
                                    </padding>
                                </HBox>
                                <VBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: #FF8286;">
                                    <children>
                                        <Label text="- Vé phải trả trước giờ khởi hành tối thiểu 12 giờ">
                                            <VBox.margin>
                                                <Insets left="10.0"/>
                                            </VBox.margin>
                                        </Label>
                                        <Label text="- Phí trả vé:">
                                            <VBox.margin>
                                                <Insets left="10.0"/>
                                            </VBox.margin>
                                        </Label>
                                        <Label text="+ Nếu trả trước giờ khởi hành &gt;= 24 giờ: hoàn 90% giá gốc.">
                                            <VBox.margin>
                                                <Insets left="10.0"/>
                                            </VBox.margin>
                                        </Label>
                                        <Label text="+ Nếu trả trước giờ khởi hành từ 12 đến 24 giờ: hoàn 70% giá gốc.">
                                            <VBox.margin>
                                                <Insets left="10.0"/>
                                            </VBox.margin>
                                        </Label>
                                        <Label text="+ Nếu trả trước giờ khởi hành &lt;= 12 giờ: không hoàn tiền.">
                                            <VBox.margin>
                                                <Insets left="10.0"/>
                                            </VBox.margin>
                                        </Label>
                                        <Label text="- Số tiền hoàn lại sẽ được thanh toán trực tiếp bằng tiền mặt tại quầy bán vé."
                                               wrapText="true">
                                            <VBox.margin>
                                                <Insets left="10.0"/>
                                            </VBox.margin>
                                        </Label>
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="15.0" left="15.0" right="15.0"/>
                                    </VBox.margin>
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0"
                                                top="10.0"/>
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>
                    </center>
                </BorderPane>

            </VBox>


            <!-- right -->
            <BorderPane fx:id="pnRight">
                <center>
                    <VBox fx:id="thongTinTraVe" alignment="TOP_CENTER"
                          style="-fx-border-color: gray;" BorderPane.alignment="CENTER">
                        <children>
                            <Label style="-fx-font-weight: bold; -fx-font-size: 16;"
                                   text="THÔNG TIN KHÁCH HÀNG MUA VÉ">
                                <VBox.margin>
                                    <Insets bottom="20.0"/>
                                </VBox.margin>
                            </Label>
                            <GridPane hgap="5.0"
                                      style="-fx-border-color: gray; -fx-border-radius: 10;"
                                      vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                </rowConstraints>
                                <children>
                                    <Label text="Họ tên:"/>
                                    <Label text="CCCD:" GridPane.rowIndex="1"/>
                                    <Label text="Số điện thoại:" GridPane.columnIndex="2"/>
                                    <Label text="Ngày sinh:" GridPane.columnIndex="2"
                                           GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtHoTen" GridPane.columnIndex="1"/>
                                    <TextField fx:id="txtCCCD_KH" GridPane.columnIndex="1"
                                               GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtSDT_KH" GridPane.columnIndex="3"/>
                                    <TextField fx:id="txtNgaySinh" GridPane.columnIndex="3"
                                               GridPane.rowIndex="1"/>
                                </children>
                                <VBox.margin>
                                    <Insets/>
                                </VBox.margin>
                                <padding>
                                    <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                </padding>

                            </GridPane>
                            <Label style="-fx-font-weight: bold; -fx-font-size: 16;"
                                   text="CHI TIẾT HÓA ĐƠN TRẢ">
                                <VBox.margin>
                                    <Insets bottom="15.0" top="20.0"/>
                                </VBox.margin>
                            </Label>
                            <Label text="Chi tiết vé trả">
                                <VBox.margin>
                                    <Insets bottom="10.0"/>
                                </VBox.margin>
                            </Label>
                            <GridPane alignment="CENTER" hgap="5.0"
                                      style="-fx-border-color: gray; -fx-border-radius: 10;"
                                      vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                </rowConstraints>
                                <children>
                                    <Label text="Mã vé:"/>
                                    <Label text="Hành khách:" GridPane.columnIndex="2"/>
                                    <Label text="Ngày khởi hành:" GridPane.rowIndex="1"/>
                                    <Label text="Toa-khoang-ghế:" GridPane.rowIndex="2"/>
                                    <Label text="Ngày đến:" GridPane.columnIndex="2"
                                           GridPane.rowIndex="1"/>
                                    <Label text="CCCD:" GridPane.columnIndex="2"
                                           GridPane.rowIndex="2"/>
                                    <Label text="Ngày đặt:" GridPane.rowIndex="3"/>
                                    <Label text="Chuyến tàu:" GridPane.columnIndex="2"
                                           GridPane.rowIndex="3"/>
                                    <TextField fx:id="txtMaVe_VeTra" GridPane.columnIndex="1"/>
                                    <TextField fx:id="txtHanhKhach" GridPane.columnIndex="3"/>
                                    <TextField fx:id="txtNgayKhoiHanh" GridPane.columnIndex="1"
                                               GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtToa_Khoang_Ghe"
                                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                    <TextField fx:id="txtNgayDat" GridPane.columnIndex="1"
                                               GridPane.rowIndex="3"/>
                                    <TextField fx:id="txtNgayDen" GridPane.columnIndex="3"
                                               GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtCCCD_VeTra" GridPane.columnIndex="3"
                                               GridPane.rowIndex="2"/>
                                    <TextField fx:id="txtChuyenTau" GridPane.columnIndex="3"
                                               GridPane.rowIndex="3"/>
                                </children>
                                <padding>
                                    <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                </padding>

                            </GridPane>
                            <Label text="Chi tiết hóa đơn">
                                <VBox.margin>
                                    <Insets bottom="10.0" top="15.0"/>
                                </VBox.margin>
                            </Label>
                            <GridPane alignment="CENTER" hgap="5.0"
                                      style="-fx-border-color: gray; -fx-border-radius: 10;"
                                      vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="100"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                </rowConstraints>
                                <children>
                                    <Label text="Mã hóa đơn:"/>
                                    <Label text="Người lập HD:" GridPane.columnIndex="2"/>
                                    <Label text="Ngày lập HD:" GridPane.rowIndex="1"/>
                                    <Label text="Giá vé:" GridPane.rowIndex="2"/>
                                    <Label text="Khách hàng:" GridPane.columnIndex="2"
                                           GridPane.rowIndex="1"/>
                                    <Label text="Phí trả vé:" GridPane.columnIndex="2"
                                           GridPane.rowIndex="2"/>
                                    <Label text="Tổng tiền" GridPane.rowIndex="3"/>
                                    <TextField fx:id="txtMaHoaDon" GridPane.columnIndex="1"/>
                                    <TextField fx:id="txtNguoiLapHD" GridPane.columnIndex="3"/>
                                    <TextField fx:id="txtNgayLapHD" GridPane.columnIndex="1"
                                               GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtGiaVe" GridPane.columnIndex="1"
                                               GridPane.rowIndex="2"/>
                                    <TextField fx:id="txtTongTien" GridPane.columnIndex="1"
                                               GridPane.rowIndex="3"/>
                                    <TextField fx:id="txtKhachHang" GridPane.columnIndex="3"
                                               GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtPhiTraVe" GridPane.columnIndex="3"
                                               GridPane.rowIndex="2"/>
                                </children>
                                <padding>
                                    <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                </padding>

                            </GridPane>
                            <Button fx:id="btnXacNhan" mnemonicParsing="false"
                                    onAction="#xacNhan"
                                    style="-fx-background-color: #52CCF6; -fx-text-fill: white"
                                    text="Xác nhận">
                                <VBox.margin>
                                    <Insets top="20.0"/>
                                </VBox.margin>
                            </Button>
                        </children>
                        <padding>
                            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                        </padding>
                    </VBox>
                </center>

                <right>
                    <VBox fx:id="traVeThanhCong" alignment="TOP_CENTER" visible="false" managed="false"
                          style="-fx-border-color: gray;"
                          BorderPane.alignment="CENTER">
                        <children>
                            <ImageView fitHeight="53.0" fitWidth="61.0" pickOnBounds="true"
                                       preserveRatio="true">
                                <image>
                                    <Image url="@../../../img/check.png"/>
                                </image>
                                <VBox.margin>
                                    <Insets top="35.0"/>
                                </VBox.margin>
                            </ImageView>
                            <Label style="-fx-font-weight: bold; -fx-font-size: 16;"
                                   text="TRẢ VÉ THÀNH CÔNG!">
                                <VBox.margin>
                                    <Insets top="15.0"/>
                                </VBox.margin>
                            </Label>
                            <Label text="Vé đã được cập nhật lại trên hệ thống.">
                                <padding>
                                    <Insets top="10.0"/>
                                </padding>
                            </Label>
                            <GridPane hgap="10.0" maxHeight="Infinity"
                                      style="-fx-border-color: gray; -fx-border-radius: 15;"
                                      vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                    <ColumnConstraints hgrow="SOMETIMES"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                    <RowConstraints vgrow="SOMETIMES"/>
                                </rowConstraints>
                                <children>
                                    <Label text="Giá vé:"/>
                                    <Label text="Phí trả vé:" GridPane.rowIndex="1"/>
                                    <Label text="Số tiền hoàn lại:" GridPane.rowIndex="2"/>
                                    <TextField fx:id="txtGiaVeDaTra" GridPane.columnIndex="1"/>
                                    <TextField fx:id="txtPhiTraVePhaiTra"
                                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtSoTienCanHoanLai"
                                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                </children>
                                <padding>
                                    <Insets bottom="20.0" left="10.0" right="10.0" top="20.0"/>
                                </padding>
                                <VBox.margin>
                                    <Insets top="15.0"/>
                                </VBox.margin>
                            </GridPane>
                            <Button fx:id="btnTraVeKhac" onAction="#traVeKhac"
                                    mnemonicParsing="false" text="Trả vé khác">
                                <VBox.margin>
                                    <Insets bottom="20.0" top="20.0"/>
                                </VBox.margin>
                            </Button>
                            <Label alignment="CENTER" contentDisplay="CENTER"
                                   text="Số tiền hoàn lại sẽ nhận trực tiếp tại quầy bán vé."
                                   textAlignment="CENTER" wrapText="true"/>
                        </children>
                        <padding>
                            <Insets left="10.0" right="10.0"/>
                        </padding>
                    </VBox>
                </right>
            </BorderPane>

        </items>
    </SplitPane>

</AnchorPane>

