<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root" prefHeight="500.0" prefWidth="600.0"
            minHeight="500.0" minWidth="600.0"
            maxHeight="500.0" maxWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.loading.LoadingController"
            style="-fx-background-color: #9ad4b3;">

    <VBox spacing="15" alignment="CENTER"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">


        <ImageView fx:id="imgLoading"
                   AnchorPane.topAnchor="0"
                   AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="0"
                   AnchorPane.rightAnchor="0"
                   preserveRatio="true"
                   smooth="true"/>

        <Label text="LOADING..."
               style="-fx-font-size: 22; -fx-font-weight: bold;"/>

        <ProgressBar fx:id="progressBar"
                     prefWidth="250"/>

        <Label fx:id="lblPercent"
               text="0%"
               style="-fx-font-size: 14;"/>
    </VBox>

</AnchorPane>
