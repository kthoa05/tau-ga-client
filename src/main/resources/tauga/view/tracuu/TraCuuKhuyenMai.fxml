<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.tracuu.TraCuuKhuyenMai"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: transparent;">

    <center>
        <VBox alignment="TOP_CENTER" spacing="15" style="-fx-padding: 20;" BorderPane.alignment="CENTER">

            <Label alignment="CENTER" contentDisplay="CENTER"
                   prefHeight="35" prefWidth="1052"
                   style="-fx-font-size: 24; -fx-font-weight: bold;"
                   text="TÌM KIẾM THÔNG TIN KHUYẾN MÃI"/>

            <!-- Date BD -->
            <!-- HÀNG TÌM KIẾM NGANG -->
            <HBox alignment="CENTER" spacing="25" style="-fx-padding: 10 20 10 20;">

                <!-- Ngày Bắt Đầu -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 14;" text="Ngày Bắt Đầu:"/>
                    <DatePicker fx:id="dpNgayBD" prefWidth="180" prefHeight="32"
                                style="
                -fx-background-color: white;
                -fx-control-inner-background: white;
                -fx-background-radius: 6;
                -fx-border-radius: 6;
                -fx-border-color: #ccc;
                -fx-padding: 0;
                -fx-arrow-button-background: white;
            "/>
                </HBox>

                <!-- Ngày Kết Thúc -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 14;" text="Ngày Kết Thúc:"/>
                    <DatePicker fx:id="dpNgayKT" prefWidth="180" prefHeight="32"
                                style="
                -fx-background-color: white;
                -fx-control-inner-background: white;
                -fx-background-radius: 6;
                -fx-border-radius: 6;
                -fx-border-color: #ccc;
                -fx-padding: 0;
                -fx-arrow-button-background: white;
            "/>
                </HBox>

                <!-- Loại Khuyến Mãi -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 14;" text="Loại Khuyến Mãi:"/>
                    <JFXComboBox fx:id="cbLoaiKhuyenMai" promptText="Tất cả"
                                 prefWidth="200" prefHeight="32"
                                 style="-fx-background-color: white; -fx-border-color: #ccc;
                    -fx-border-radius: 6; -fx-background-radius: 6;
                    -fx-font-size: 13; -fx-padding: 0 8 0 8;
                    -jfx-focus-color: transparent; -jfx-unfocus-color: transparent;"/>
                </HBox>

                <!-- Trạng Thái -->
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 14;" text="Trạng Thái:"/>
                    <JFXComboBox fx:id="cbTrangThai" promptText="Tất cả"
                                 prefWidth="200" prefHeight="32"
                                 style="-fx-background-color: white; -fx-border-color: #ccc;
                    -fx-border-radius: 6; -fx-background-radius: 6;
                    -fx-font-size: 13; -fx-padding: 0 8 0 8;
                    -jfx-focus-color: transparent; -jfx-unfocus-color: transparent;"/>
                </HBox>

            </HBox>

            <HBox alignment="CENTER_RIGHT" prefWidth="1052" spacing="10" style="-fx-padding: 0 40 0 0;">
                <Button fx:id="btnTimKiem"
                        onAction="#onTimKiem"
                        alignment="CENTER"
                        style="-fx-background-color: #52CCF6;
                               -fx-cursor: hand;-fx-text-fill: white;-fx-font-weight: bold;-fx-background-radius: 6; -fx-padding: 8 16;"
                        text="Tìm Kiếm"/>

                <Button fx:id="btnXoaTrang"
                        onAction="#onXoaTrang"
                        alignment="CENTER"
                        style="-fx-background-color: #52CCF6;
                               -fx-cursor: hand;-fx-text-fill: white;-fx-font-weight: bold;-fx-background-radius: 6; -fx-padding: 8 16;"
                        text="Làm Mới"/>
            </HBox>

            <!-- TABLE VIEW -->
            <TableView fx:id="tableKhuyenMai"
                       style="-fx-border-color: #ddd; -fx-border-radius: 5;"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaKM" style="-fx-alignment: CENTER;" text="Mã Khuyến Mãi"/>
                    <TableColumn fx:id="colTenKM" style="-fx-alignment: CENTER_LEFT;" text="Tên Khuyến Mãi"/>
                    <TableColumn fx:id="colMoTa" style="-fx-alignment: CENTER_LEFT;" text="Thông Tin Mô Tả"/>
                    <TableColumn fx:id="colNgayBD" style="-fx-alignment: CENTER;" text="Ngày Bắt Đầu"/>
                    <TableColumn fx:id="colNgayKT" style="-fx-alignment: CENTER;" text="Ngày Kết Thúc"/>
                    <TableColumn fx:id="colGiaTriTien" style="-fx-alignment: CENTER_RIGHT;" text="Giá Trị Tiền"/>
                    <TableColumn fx:id="colGiaTriPT" style="-fx-alignment: CENTER_RIGHT;" text="Giá Trị Phần Trăm"/>
                    <TableColumn fx:id="colLoaiKM" style="-fx-alignment: CENTER;" text="Loại Khuyến Mãi"/>
                    <TableColumn fx:id="colTrangThai" style="-fx-alignment: CENTER;" text="Trạng Thái"/>
                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

        </VBox>
    </center>

</BorderPane>
