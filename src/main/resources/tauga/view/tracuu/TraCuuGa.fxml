<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>


<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.tracuu.TraCuuGa"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: transparent;">

    <center>
        <VBox alignment="TOP_CENTER" spacing="15" style="-fx-padding: 20;" BorderPane.alignment="CENTER">

            <Label alignment="CENTER" contentDisplay="CENTER"
                   prefHeight="35" prefWidth="1052"
                   style="-fx-font-size: 24; -fx-font-weight: bold;"
                   text="TRA CỨU GA"/>

            <HBox alignment="CENTER" spacing="30" style="-fx-padding: 10 20 10 20;">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 14;" text="Tên Ga:"/>
                    <JFXComboBox fx:id="cbTenGa" promptText="Tất cả" prefWidth="200"
                                 style="-fx-background-color: white;
                            -fx-border-color: #ccc;
                            -fx-border-radius: 6;
                            -fx-background-radius: 6;
                            -fx-padding: 0 8;
                            -fx-font-size: 13;
                            -jfx-focus-color: transparent;
                            -jfx-unfocus-color: transparent;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size: 14;" text="Địa Chỉ:"/>
                    <TextField fx:id="txtDiaChi" promptText="Nhập địa chỉ" prefWidth="250"
                               style="-fx-font-size: 13; -fx-background-radius: 6; -fx-border-radius: 6;"/>
                </HBox>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 0 20 10 20;">
                <Button fx:id="btnTimKiem" onAction="#onTimKiem" text="Tìm Kiếm"
                        style="-fx-background-color: #52CCF6; -fx-cursor: hand;
                   -fx-text-fill: white; -fx-font-weight: bold;
                   -fx-background-radius: 6; -fx-padding: 8 16;"/>
                <Button fx:id="btnXoaTrang" onAction="#onXoaTrang" text="Làm Mới"
                        style="-fx-background-color: #52CCF6; -fx-cursor: hand;
                   -fx-text-fill: white; -fx-font-weight: bold;
                   -fx-background-radius: 6; -fx-padding: 8 16;"/>
            </HBox>

            <TableView fx:id="tableGa"
                       style="-fx-border-color: #ddd; -fx-border-radius: 5;"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaGa" text="Mã Ga" prefWidth="200" minWidth="100" maxWidth="200"/>
                    <TableColumn fx:id="colTenGa" text="Tên Ga" prefWidth="200" minWidth="100" maxWidth="200"/>
                    <TableColumn fx:id="colDiaChi" text="Địa Chỉ"/>
                    <TableColumn fx:id="colSoChuyen" text="Số Chuyến" prefWidth="90" minWidth="60" maxWidth="120"/>
                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

        </VBox>
    </center>

</BorderPane>
