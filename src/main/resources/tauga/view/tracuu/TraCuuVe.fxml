<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="contentArea" prefHeight="700" prefWidth="1200" style="-fx-background-color: transparent;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controller.tracuu.TraCuuVe">
    <center>
        <VBox alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="TOP_CENTER">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 25;" text="TRA CỨU THÔNG TIN VÉ TÀU" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="50.0">
                    <children>
                        <Label fx:id="lblChonCachTraCuu" text="Chọn cách thức tra cứu:">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <RadioButton fx:id="radMaVe" mnemonicParsing="false" text="Mã vé">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </RadioButton>
                        <RadioButton fx:id="radThongTinKH" mnemonicParsing="false" text="Thông tin khách hàng">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </RadioButton>
                    </children>
                    <VBox.margin>
                        <Insets left="100" />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox fx:id="HBoxMaVe" alignment="CENTER_LEFT" spacing="50.0">
                    <children>
                        <Label fx:id="lblMaVe" text="Mã vé:">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtMaVe" prefHeight="31.0" prefWidth="270.0" />
                        <ImageView fitHeight="29.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../../img/qr.png" />
                            </image>
                        </ImageView>
                    </children>
                    <VBox.margin>
                        <Insets left="100" />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>

                <HBox fx:id="HBoxThongTinKH" alignment="CENTER_LEFT" managed="false" spacing="50.0" visible="false">
                    <children>
                        <Label fx:id="lblSDT" text="Số điện thoại:">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtSDT" prefHeight="31.0" prefWidth="270.0" />
                        <Label fx:id="lblCCCD" text="CCCD:">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtCCCD" prefHeight="31.0" prefWidth="270.0" />
                    </children>
                    <VBox.margin>
                        <Insets left="100.0" />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Button fx:id="btnTimKiem" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#timKiem" prefWidth="80"
                                style="-fx-background-color: #52CCF6; -fx-text-fill: white" text="Tìm kiếm" />

                        <Button fx:id="btnXoaTrang" mnemonicParsing="false" onAction="#xoaTrang" prefWidth="80"
                                style="-fx-background-color: #52CCF6; -fx-text-fill: white" text="Làm mới" />

                        <Button fx:id="btnInVe" mnemonicParsing="false" onAction="#inVe" prefWidth="80"
                                style="-fx-background-color: #52CCF6; -fx-text-fill: white" text="In vé" />
                        <Button fx:id="btnDoiVe" mnemonicParsing="false" onAction="#doiVe" prefWidth="80"
                                style="-fx-background-color: #52CCF6; -fx-text-fill: white" text="Đổi vé" />
                        <Button fx:id="btnTraVe" mnemonicParsing="false" onAction="#traVe" prefWidth="80"
                                style="-fx-background-color: #52CCF6; -fx-text-fill: white" text="Trả vé" />
                    </children>
                </HBox>

                <TableView fx:id="table">
                    <columns>
                        <TableColumn fx:id="colMaVe" text="Mã vé" />
                        <TableColumn fx:id="colTenKH" text="Tên khách hàng" />
                        <TableColumn fx:id="colChuyenTau" text="Chuyến tàu" />
                        <TableColumn fx:id="colNgayDat" text="Ngày đặt" />
                        <TableColumn fx:id="colGiaVe" text="Giá vé" />
                        <TableColumn fx:id="colTrangThaiVe" text="Trạng thái vé" />
                    </columns>
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" />
            </padding>
        </VBox>
    </center>

</BorderPane>
