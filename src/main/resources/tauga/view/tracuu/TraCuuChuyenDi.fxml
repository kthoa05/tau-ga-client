<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.tracuu.TraCuuChuyenDi"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: transparent;">

    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;" BorderPane.alignment="CENTER">

            <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="35.0" prefWidth="1052.0"
                   style="-fx-font-size: 24; -fx-font-weight: bold;"
                   text="TRA CỨU THÔNG TIN CHUYẾN ĐI"/>

            <HBox alignment="CENTER" spacing="35" style="-fx-padding: 10 20 10 20;" prefWidth="Infinity">

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <children>
                        <Label style="-fx-font-size: 14;" text="Ga Đi:"/>
                        <JFXComboBox fx:id="cbGaDi" promptText="Tất cả" prefWidth="260" prefHeight="26"
                                     style="-fx-background-color: white;
                            -fx-border-color: #ccc;
                            -fx-border-radius: 6;
                            -fx-background-radius: 6;
                            -fx-padding: 0 8;
                            -fx-font-size: 13;
                            -jfx-focus-color: transparent;
                            -jfx-unfocus-color: transparent;"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <children>
                        <Label style="-fx-font-size: 14;" text="Ga Đến:"/>
                        <JFXComboBox fx:id="cbGaDen" promptText="Tất cả" prefWidth="260" prefHeight="26"
                                     style="-fx-background-color: white;
                            -fx-border-color: #ccc;
                            -fx-border-radius: 6;
                            -fx-background-radius: 6;
                            -fx-padding: 0 8;
                            -fx-font-size: 13;
                            -jfx-focus-color: transparent;
                            -jfx-unfocus-color: transparent;"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <children>
                        <Label style="-fx-font-size: 14;" text="Ngày Đi:"/>
                        <DatePicker fx:id="dpNgayDi" prefWidth="260" prefHeight="32"
                                    style="
                -fx-background-color: white;
                -fx-control-inner-background: white;
                -fx-background-radius: 6;
                -fx-border-radius: 6;
                -fx-border-color: #ccc;
                -fx-padding: 0;
                -fx-arrow-button-background: white;
            "/>

                    </children>
                </HBox>

            </HBox>

            <HBox alignment="CENTER_RIGHT" prefWidth="1052" spacing="10" style="-fx-padding: 0 40 0 0;">
                <Button fx:id="btnTimKiem" onAction="#onTimKiem" text="Tìm Kiếm"
                        style="-fx-background-color: #52CCF6; -fx-cursor: hand;-fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16;"/>

                <Button fx:id="btnXoaTrang" onAction="#onXoaTrang" text="Làm Mới"
                        style="-fx-background-color: #52CCF6;; -fx-cursor: hand;-fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16;"/>
            </HBox>


            <TableView fx:id="tableChuyenDi" style="-fx-border-color: #ddd; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSTT" text="STT" prefWidth="50" minWidth="40" maxWidth="60"/>
                    <TableColumn fx:id="colMaChuyen" text="Mã Chuyến Đi" prefWidth="260"/>
                    <TableColumn fx:id="colMaTau" text="Mã Tàu" prefWidth="120"/>
                    <TableColumn fx:id="colGaDi" text="Ga Đi" prefWidth="120"/>
                    <TableColumn fx:id="colGaDen" text="Ga Đến" prefWidth="120"/>
                    <TableColumn fx:id="colThoiGianDi" text="Thời Gian Khởi Hành" prefWidth="150"/>
                    <TableColumn fx:id="colThoiGianDen" text="Thời Gian Đến Dự Kiến" prefWidth="170"/>
                    <TableColumn fx:id="colCuLy" text="Cự Ly (KM)" prefWidth="100"/>
                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

        </VBox>
    </center>
</BorderPane>
