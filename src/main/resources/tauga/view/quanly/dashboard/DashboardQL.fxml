<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="contentArea" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ql.dashboard.DashboardQL">

    <children>
        <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <top>
                <HBox alignment="CENTER" spacing="350.0" BorderPane.alignment="CENTER" >
                    <children>

                        <VBox alignment="CENTER" prefWidth="350.0" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10,0,0,2);">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="TỔNG DOANH THU THEO NGÀY" />
                                <Label style="-fx-text-fill: blue; -fx-font-size: 15;" text="650 triệu VND" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefWidth="350.0" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10,0,0,2);">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="TỔNG SỐ CHUYẾN TÀU CHẠY TRONG NGÀY" />
                                <Label style="-fx-text-fill: blue; -fx-font-size: 15;" text="7 chuyến" />
                            </children>
                        </VBox>

                    </children>
                    <BorderPane.margin>
                        <Insets bottom="5.0" top="10.0" />
                    </BorderPane.margin>
                </HBox>
            </top>
         <bottom>
                <HBox spacing="15" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
<!--                    Biểu đồ đường-->
                    <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10,0,0,3);">
                        <children>
                            <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Doanh thu theo ngày" />
                            <LineChart onMouseClicked="#linkToDoanhThu" maxHeight="250.0" VBox.vgrow="ALWAYS" fx:id="doanhThuTheoNgay">
                                <xAxis>
                                    <CategoryAxis label="Ca làm việc"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Doanh thu (Triệu VND)"/>
                                </yAxis>
                            </LineChart>
                        </children>
                    </VBox>

<!--                    Biểu đồ đường-->
                    <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10,0,0,3);">
                        <children>
                            <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Chuyến tàu chạy theo ngày" />
                     <LineChart onMouseClicked="#linkToChuyenTauTheoNgay" maxHeight="250.0" VBox.vgrow="ALWAYS" fx:id="lineChartChuyenTau">
                       <xAxis>
                         <CategoryAxis side="BOTTOM" label="Ca làm việc"/>
                       </xAxis>
                       <yAxis>
                         <NumberAxis side="LEFT" label="Số lượng chuyến tàu"/>
                       </yAxis>
                     </LineChart>
                        </children>
                    </VBox>

                </HBox>
         </bottom>
         <center>
            <HBox spacing="15" BorderPane.alignment="CENTER" >
               <padding>
                  <Insets left="10.0" right="10.0" top="8.0" />
               </padding>
               <children>
<!--                   Biểu đồ cột dọc-->
                  <VBox HBox.hgrow="ALWAYS" spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10,0,0,3);">
                     <children>
                        <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Số lượng vé theo chuyến" />
                        <BarChart onMouseClicked="#linkToSoLuongVeTheoChuyen" maxHeight="250" VBox.vgrow="ALWAYS" fx:id="soLuongVeTheoChuyen">
                          <xAxis>
                            <CategoryAxis side="BOTTOM" label="Chuyến tàu"/>
                          </xAxis>
                          <yAxis>
                            <NumberAxis side="LEFT" label="Số lượng vé"/>
                          </yAxis>
                        </BarChart>
                     </children>
                  </VBox>

<!--                   Biểu đồ cột-->
                  <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10,0,0,3);">
                     <children>
                        <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Top 5 chuyến tàu đông khách" />
                        <BarChart onMouseClicked="#linkToTop5ChuyenTauDongKhach" maxHeight="250" VBox.vgrow="ALWAYS" fx:id="barChartTop5">
                           <xAxis>
                              <CategoryAxis label="Chuyến tàu"/>
                           </xAxis>
                           <yAxis>
                              <NumberAxis/>
                           </yAxis>
                        </BarChart>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </center>

        </BorderPane>
    </children>
</AnchorPane>
