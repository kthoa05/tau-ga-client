<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<StackPane fx:id="root" prefHeight="500.0" prefWidth="600.0"
           minHeight="500.0" minWidth="600.0"
           maxHeight="500.0" maxWidth="600.0"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.authen.DangNhap">

    <ImageView fx:id="anhNen" fitHeight="500.0" fitWidth="600.0" preserveRatio="false">
        <image>
            <Image url="@../../img/tau.jpg"/>
        </image>
    </ImageView>

    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.75), 10, 0.5, 0, 2);"
               text="Hệ thống quản lý bán vé tàu" textAlignment="CENTER">
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
        </Label>

        <VBox alignment="CENTER" maxWidth="420.0" prefWidth="420.0" spacing="12.0"
              style="-fx-background-color: #FFFBEB; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 8, 0.4, 0, 5);">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="20.0"/>
            </padding>
            <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #222;" text="ĐĂNG NHẬP"/>

            <VBox maxWidth="360.0" spacing="6.0">
                <Label style="-fx-font-size: 15; -fx-font-weight: bold;" text="Tên đăng nhập"/>
                <HBox alignment="CENTER_LEFT" spacing="8.0"
                      style="-fx-background-color: white; -fx-border-color: #d0d0d0; -fx-border-radius: 5; -fx-padding: 4 8;">
                    <ImageView fitHeight="22.0" fitWidth="22.0">
                        <image>
                            <Image url="@../../img/userdn.png"/>
                        </image>
                    </ImageView>
                    <TextField fx:id="txtTenDangNhap" prefHeight="38.0" promptText="an.nguyen"
                               style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
                        <font>
                            <Font size="13.0"/>
                        </font>
                    </TextField>
                </HBox>
            </VBox>

            <VBox maxWidth="360.0" spacing="6.0">
                <Label style="-fx-font-size: 15; -fx-font-weight: bold;" text="Mật khẩu"/>
                <HBox alignment="CENTER_LEFT" spacing="8.0"
                      style="-fx-background-color: white; -fx-border-color: #d0d0d0; -fx-border-radius: 5; -fx-padding: 4 8;">
                    <ImageView fitHeight="22.0" fitWidth="22.0">
                        <image>
                            <Image url="@../../img/password.png"/>
                        </image>
                    </ImageView>
                    <PasswordField fx:id="txtMatKhau" prefHeight="38.0" promptText="********"
                                   style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
                        <font>
                            <Font size="13.0"/>
                        </font>
                    </PasswordField>
                    <TextField fx:id="txtMatKhauHien" prefHeight="38.0" promptText="********"
                               style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS"
                               visible="false" managed="false">
                        <font>
                            <Font size="13.0"/>
                        </font>
                    </TextField>
                </HBox>
            </VBox>

        <HBox alignment="CENTER_LEFT" prefWidth="360.0" spacing="8.0">
            <CheckBox fx:id="chkHienMatKhau" onAction="#hienMK" style="-fx-font-size: 13px;"
                      text="Hiển thị mật khẩu">
            <HBox.margin>
                <Insets left="9.0" /> </HBox.margin>
        </CheckBox>
        </HBox>
            <Hyperlink fx:id="btnQuenMK" onAction="#quenMatKhau" style="-fx-font-size: 13;" text="Quên mật khẩu?"/>

        <HBox alignment="CENTER" maxWidth="360.0" spacing="12.0">
                <Button fx:id="btnDangNhap" onAction="#dangNhap" prefHeight="40.0" prefWidth="180.0"
                        style="-fx-background-color: #52CCF6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand;;"
                        text="Đăng nhập"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>